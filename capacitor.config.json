{
  "appId": "com.novashield.vpn",
  "appName": "NovaSHIELD VPN",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0f172a",
      "showSpinner": true,
      "spinnerColor": "#22d3ee"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_shield",
      "iconColor": "#22d3ee"
    }
  }
}
